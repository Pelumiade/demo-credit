{
  "name": "demo-credit",
  "version": "1.0.0",
  "description": "MVP wallet service — Lendsqr backend engineering assessment",
  "main": "dist/server.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "build": "tsc",
    "postinstall": "npm run build",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "migrate": "npm run build && knex --knexfile knexfile.js migrate:latest",
    "migrate:test": "npm run build && NODE_ENV=test knex --knexfile knexfile.js migrate:latest",
    "migrate:rollback": "npm run build && knex --knexfile knexfile.js migrate:rollback",
    "seed": "npm run build && knex --knexfile knexfile.js seed:run",
    "test": "jest --runInBand --forceExit",
    "test:e2e": "jest --config jest.e2e.config.ts --runInBand --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand --forceExit"
  },
  "dependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^9.0.7",
    "axios": "^1.6.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "knex": "^3.1.0",
    "mysql2": "^3.6.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.0",
    "@types/supertest": "^2.0.16",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  }
}
