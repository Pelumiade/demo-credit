{
  "openapi": "3.0.3",
  "info": {
    "title": "Demo Credit — Wallet API",
    "description": "MVP wallet service for the Lendsqr backend assessment. Registration stores a **bcrypt** hash of the password (never returned). API access after signup uses a faux Bearer token: `Bearer faux-token-<userId>`.",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "/", "description": "Current host" }
  ],
  "tags": [
    { "name": "Auth" },
    { "name": "Wallet" }
  ],
  "components": {
    "securitySchemes": {
      "FauxBearer": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "faux-token-<userId>",
        "description": "Use the token returned from `POST /auth/register` (format: `faux-token-<uuid>`)."
      }
    },
    "schemas": {
      "ApiSuccess": {
        "type": "object",
        "required": ["success", "message"],
        "properties": {
          "success": { "type": "boolean", "example": true },
          "message": { "type": "string" },
          "data": {}
        }
      },
      "ApiError": {
        "type": "object",
        "required": ["success", "message"],
        "properties": {
          "success": { "type": "boolean", "example": false },
          "message": { "type": "string" },
          "data": {}
        }
      },
      "RegisterRequest": {
        "type": "object",
        "required": ["name", "email", "phone", "password"],
        "properties": {
          "name": { "type": "string" },
          "email": { "type": "string", "format": "email", "description": "Validated and normalized (trim + lowercase)." },
          "phone": { "type": "string" },
          "password": { "type": "string", "format": "password", "minLength": 8, "maxLength": 128, "description": "Stored as a bcrypt hash; not echoed in responses." }
        }
      },
      "RegisterResponse": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "message": { "type": "string" },
          "data": {
            "type": "object",
            "properties": {
              "user": {
                "type": "object",
                "properties": {
                  "id": { "type": "string", "format": "uuid" },
                  "name": { "type": "string" },
                  "email": { "type": "string" },
                  "phone": { "type": "string" },
                  "created_at": { "type": "string", "format": "date-time" }
                }
              },
              "token": { "type": "string", "description": "faux-token-<userId>" }
            }
          }
        }
      },
      "FundRequest": {
        "type": "object",
        "required": ["amount"],
        "properties": {
          "amount": { "type": "number", "minimum": 0.01, "description": "Must be a positive number" }
        }
      },
      "TransferRequest": {
        "type": "object",
        "required": ["recipient_email", "amount"],
        "properties": {
          "recipient_email": { "type": "string", "format": "email" },
          "amount": { "type": "number", "minimum": 0.01 }
        }
      },
      "WithdrawRequest": {
        "type": "object",
        "required": ["amount"],
        "properties": {
          "amount": { "type": "number", "minimum": 0.01 }
        }
      }
    }
  },
  "paths": {
    "/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Create account",
        "description": "Registers a user and wallet. Checks Lendsqr Adjutor Karma before onboarding.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/RegisterRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/RegisterResponse" }
              }
            }
          },
          "400": {
            "description": "Validation error",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } }
            }
          },
          "403": {
            "description": "Karma blacklist / account creation denied",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } }
            }
          },
          "409": {
            "description": "Email already registered",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } }
            }
          },
          "500": {
            "description": "Server error (e.g. Karma service unavailable)",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } }
            }
          }
        }
      }
    },
    "/wallet/balance": {
      "get": {
        "tags": ["Wallet"],
        "summary": "Get wallet balance",
        "security": [{ "FauxBearer": [] }],
        "responses": {
          "200": {
            "description": "Balance",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiSuccess" },
                    {
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "balance": { "description": "May be returned as string (DECIMAL) or number" }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } }
            }
          },
          "404": {
            "description": "Wallet not found",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } }
            }
          }
        }
      }
    },
    "/wallet/transactions": {
      "get": {
        "tags": ["Wallet"],
        "summary": "List transactions for the authenticated wallet",
        "security": [{ "FauxBearer": [] }],
        "responses": {
          "200": {
            "description": "Transaction history",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiSuccess" },
                    {
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "transactions": {
                              "type": "array",
                              "items": { "type": "object", "additionalProperties": true }
                            }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } }
            }
          }
        }
      }
    },
    "/wallet/fund": {
      "post": {
        "tags": ["Wallet"],
        "summary": "Fund wallet",
        "security": [{ "FauxBearer": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/FundRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Wallet funded",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiSuccess" },
                    {
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "balance": { "type": "number" }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Invalid amount",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } }
            }
          },
          "404": {
            "description": "Wallet not found",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } }
            }
          }
        }
      }
    },
    "/wallet/transfer": {
      "post": {
        "tags": ["Wallet"],
        "summary": "Transfer to another user by email",
        "security": [{ "FauxBearer": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/TransferRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Transfer successful",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiSuccess" }
              }
            }
          },
          "400": {
            "description": "Validation error or cannot transfer to self",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } }
            }
          },
          "404": {
            "description": "Recipient or wallet not found",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } }
            }
          },
          "422": {
            "description": "Insufficient funds",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } }
            }
          },
          "500": {
            "description": "Server error",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } }
            }
          }
        }
      }
    },
    "/wallet/withdraw": {
      "post": {
        "tags": ["Wallet"],
        "summary": "Withdraw from wallet",
        "security": [{ "FauxBearer": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/WithdrawRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Withdrawal successful",
            "content": {
              "application/json": {
                "schema": {
                  "allOf": [
                    { "$ref": "#/components/schemas/ApiSuccess" },
                    {
                      "properties": {
                        "data": {
                          "type": "object",
                          "properties": {
                            "balance": { "type": "number" }
                          }
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Invalid amount",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } }
            }
          },
          "404": {
            "description": "Wallet not found",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } }
            }
          },
          "422": {
            "description": "Insufficient funds",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/ApiError" } }
            }
          }
        }
      }
    }
  }
}
